class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        long long maxsum=0,sum=0;
        int n=nums.size();

        for(int i=0;i<k;i++){
            sum+=nums[i];
        }
        maxsum=sum;
        for(int i=k;i<n;i++){
            sum+=nums[i];
            sum-=nums[i-k];
            maxsum=max(sum,maxsum);
        }
        return (double)maxsum/k;
    }
};