class Solution {
public:
    bool isPalindrome(string s) {
        string newS;
        for(char ch:s){
            if(isalnum(ch)){
                newS+=tolower(ch);
            }
        }
        int flag=false;
        int n=newS.size();
        for(int i=0;i<n/2;i++){
            if(newS[i]!=newS[n-i-1]){
                return false;
            }
        }
        return true;
    }
};