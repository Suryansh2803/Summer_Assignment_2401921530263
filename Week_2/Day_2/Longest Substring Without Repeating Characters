class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int n=s.size();
        set<char> st;
        int left=0,len=0;
        int maxlen=0;
        for(int right=0;right<n;right++){
            while(st.contains(s[right])){
                    st.erase(s[left]);
                    left++;
                }
                st.insert(s[right]);
                len=right-left+1;
                maxlen=max(len,maxlen);
            }
        
    return maxlen;
    }
};