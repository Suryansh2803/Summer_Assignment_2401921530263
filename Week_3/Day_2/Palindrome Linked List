class Solution {
public:
    bool isPalindrome(ListNode* head) {
          if(head == NULL || head->next == NULL) return true;

        ListNode* slow = head;
        ListNode* fast = head;

        // Find middle
        while(fast != NULL && fast->next != NULL){
            slow = slow->next;
            fast = fast->next->next;
        }

        // Skip middle for odd length
        if(fast != NULL) {
            slow = slow->next;
        }

        // Reverse second half
        ListNode* prev = NULL;
        while(slow != NULL){
            ListNode* next = slow->next;
            slow->next = prev;
            prev = slow;
            slow = next;
        }

        // Compare
        ListNode* p1 = head;
        ListNode* p2 = prev;

        while(p2 != NULL){
            if(p1->val != p2->val)
                return false;

            p1 = p1->next;
            p2 = p2->next;
        }

        return true;
    }
};